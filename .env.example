# ==========================================
# Core Django
# ==========================================
# Leave DEBUG=True for local development. In production set DEBUG=False (and then
# SECRET_KEY and DATABASE_URL become mandatory — the app refuses to boot without them).
DEBUG=True

# Generate a strong key for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY="change-me"

ALLOWED_HOSTS=127.0.0.1,localhost,.localhost

# Base domain used to build tenant subdomains. Keep 'localhost' in dev.
#
# ⚠️ Testing workspace switching locally: on plain 'localhost' the session cookie
# is NOT shared across tenant subdomains, so jumping to another workspace's
# subdomain lands you logged-out there (a localhost cookie limitation, not a bug).
# To test cross-workspace navigation like production, use a wildcard dev domain
# that points to 127.0.0.1, e.g. lvh.me:
#   PUBLIC_DOMAIN=lvh.me
#   ALLOWED_HOSTS=lvh.me,.lvh.me
# Then recreate the workspaces (their domains are derived from PUBLIC_DOMAIN) and
# access the app via http://<company>.lvh.me:8000/. The session is then shared
# across *.lvh.me. In production, a real domain handles this natively.
PUBLIC_DOMAIN=localhost

# ==========================================
# Database
# ==========================================
# In dev you may leave this empty to use the local docker-compose Postgres fallback.
# In production this is REQUIRED, e.g.:
#   postgres://user:password@host:5432/dbname
DATABASE_URL=

# ==========================================
# Real-time notifications (Channels / WebSocket)
# ==========================================
# Channel layer backend. Leave empty in dev (uses an in-memory layer, fine for a
# single `runserver` process). In production (or multiple workers) set Redis:
#   redis://localhost:6379/0   (or redis://redis:6379/0 inside docker-compose)
REDIS_URL=

# Built-in notification cleanup scheduler (deletes old notifications periodically).
# Runs inside the server process — no cron/Celery needed. Set ENABLED=False if you
# schedule `manage.py cleanup_notifications` externally instead.
NOTIFICATION_CLEANUP_ENABLED=True
NOTIFICATION_CLEANUP_INTERVAL_HOURS=24

# ==========================================
# Security (production)
# ==========================================
# Comma-separated. Auto-derived from PUBLIC_DOMAIN if left empty, e.g.:
#   https://yourdomain.com,https://*.yourdomain.com
CSRF_TRUSTED_ORIGINS=
# Set to False only if TLS is terminated elsewhere and a redirect loop occurs.
SECURE_SSL_REDIRECT=True

# ==========================================
# Brute-force protection (django-axes)
# ==========================================
AXES_ENABLED=True
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_HOURS=1

# ==========================================
# Email
# ==========================================
# In dev, leave EMAIL_BACKEND empty to print emails to the console.
# To see real rendered emails in dev, start the Mailpit container and set:
#   EMAIL_HOST=localhost
#   EMAIL_PORT=1025
# Then open http://localhost:8025 to view the inbox.
# In production, configure SMTP credentials below.
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@example.com

# ==========================================
# Error monitoring (Sentry)
# ==========================================
# Set to your Sentry project DSN to enable error tracking in production.
# Leave empty to disable (no error is raised if unset).
SENTRY_DSN=
# Fraction of transactions to capture for performance tracing (0.0–1.0).
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==========================================
# Logging / Gunicorn
# ==========================================
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
# Set LOG_FORMAT=json in production to emit structured JSON logs (for CloudWatch / Loki / Datadog).
LOG_FORMAT=text
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
